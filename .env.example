# ── MongoDB Atlas ──────────────────────────────────────────────
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Then Network Access → 0.0.0.0/0, Database Access → create a user.
# Copy the SRV connection string and append /rekart_oms before the ? query.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/rekart_oms?retryWrites=true&w=majority

# ── Auth ───────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
